SECOPS_REPO_ROOT=/path/to/CTF
# Keep runtime data on local user-owned storage. Default:
# ${XDG_STATE_HOME:-$HOME/.local/state}/ctf-security-ops/<repo-name>-<repo-hash>
SECOPS_RUNTIME_ROOT=
SECOPS_REPORTS_ROOT=
SECOPS_ARTIFACTS_ROOT=
SECOPS_SHARED_ROOT=
VANTIX_SKILLS_ROOT=${SECOPS_REPO_ROOT}/agent_skills
SECOPS_DATABASE_URL=
SECOPS_API_TOKEN=change-me
VANTIX_SECRET_KEY=
SECOPS_CODEX_BIN=codex
SECOPS_DEFAULT_MODEL=gpt-5.4
SECOPS_DEFAULT_REASONING_EFFORT=medium
SECOPS_CVE_SEARCH_URL=http://127.0.0.1:5000
SECOPS_ENABLE_CVE_MCP=false
SECOPS_CVE_MCP_PATH=/mcp/cve
SECOPS_CVE_MCP_REQUIRE_TOKEN=true
SECOPS_CVE_MCP_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost
SECOPS_UI_HOST=127.0.0.1
SECOPS_UI_PORT=4173
# Execution surfaces are OFF by default. Flip to true only when you
# understand the blast radius (subprocess / Codex / filesystem writes).
SECOPS_ENABLE_CODEX_EXECUTION=false
SECOPS_ENABLE_SCRIPT_EXECUTION=false
SECOPS_ENABLE_WRITE_EXECUTION=false
# Set SECOPS_DEV_MODE=1 to allow boot without an API token (DEV ONLY).
SECOPS_DEV_MODE=false
# CORS allowlist for the browser UI (comma-separated origins).
SECOPS_CORS_ALLOW_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
OPERATOR_NAME=operator

# Users + roles auth. First boot with empty users table creates the admin
# account from these env vars, then you can create additional users.
SECOPS_ADMIN_USERNAME=
SECOPS_ADMIN_PASSWORD=
# Session cookie TTL in hours (default 12).
SECOPS_SESSION_TTL_HOURS=12
# Set to true behind HTTPS so session cookies carry the Secure flag.
SECOPS_SESSION_COOKIE_SECURE=false
# Optional: allow legacy Bearer-token service clients to keep working alongside
# cookie auth. Leave disabled unless you need programmatic access.
SECOPS_SERVICE_TOKEN_ENABLED=false

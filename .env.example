SECOPS_REPO_ROOT=/path/to/CTF
# Keep runtime data on local user-owned storage. Default:
# ${XDG_STATE_HOME:-$HOME/.local/state}/ctf-security-ops/<repo-name>-<repo-hash>
SECOPS_RUNTIME_ROOT=
SECOPS_REPORTS_ROOT=
SECOPS_ARTIFACTS_ROOT=
SECOPS_SHARED_ROOT=
VANTIX_SKILLS_ROOT=${SECOPS_REPO_ROOT}/agent_skills
SECOPS_DATABASE_URL=
SECOPS_API_TOKEN=change-me
VANTIX_SECRET_KEY=
SECOPS_CODEX_BIN=codex
SECOPS_DEFAULT_MODEL=gpt-5.4
SECOPS_DEFAULT_REASONING_EFFORT=medium
SECOPS_CVE_SEARCH_URL=http://127.0.0.1:5000
SECOPS_ENABLE_CVE_MCP=false
SECOPS_CVE_MCP_PATH=/mcp/cve
SECOPS_CVE_MCP_REQUIRE_TOKEN=true
SECOPS_CVE_MCP_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost
SECOPS_UI_HOST=127.0.0.1
SECOPS_UI_PORT=4173
SECOPS_ENABLE_CODEX_EXECUTION=false
SECOPS_ENABLE_SCRIPT_EXECUTION=true
SECOPS_ENABLE_WRITE_EXECUTION=true
OPERATOR_NAME=operator
